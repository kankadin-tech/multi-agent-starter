# 볼트 브리지 설정 — _shared/adapters/export_to_vault.sh 가 읽음.
# 이 하네스 폴더의 산출물을 어느 LLM Wiki 볼트로 내보낼지 지정한다.
# 우선순위: --vault 플래그 > KNOT_VAULT 환경변수 > 이 파일 > 스크립트 기본값($HOME/vaults/kankadin-wiki)
# ~ 또는 $HOME 으로 시작하면 홈 디렉토리로 확장된다. 볼트 미사용 폴더면 이 줄을 비워도 됨.
vault=~/vaults/kankadin-wiki

# (선택) 볼트 내 목적지 하위경로. 폴더별 분리용. 미지정 시 inbox/notes/_misc.
# 볼트 /inbox 규약상 inbox/{타입}/{도메인} 구조 권장(예: notes/co-work → 도메인 co-work로 인식).
# inbox_dir=inbox/notes/_misc
